{
  "name": "shopsmart-backend",
  "version": "1.0.0",
  "description": "Backend API for ShopSmart",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "vitest run",
    "test:integration": "jest --forceExit --detectOpenHandles --testPathPattern integration",
    "lint": "eslint . --ext js --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write ."
  },
  "jest": {
    "testEnvironment": "node"
  },
  "dependencies": {
    "@libsql/client": "^0.17.3",
    "@prisma/adapter-libsql": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "nodemon": "^3.1.0",
    "prettier": "^3.8.3",
    "prisma": "^7.8.0",
    "supertest": "^6.3.4",
    "vitest": "^3.1.1"
  }
}
