# ---- Builder stage ----
# Use pinned Node.js Alpine base image for reproducible builds
FROM node:22-alpine3.21 AS builder

# Set working directory
WORKDIR /app

# Copy package files and install production dependencies only
COPY server/package*.json ./
RUN npm ci --omit=dev

# ---- Runtime stage ----
FROM node:22-alpine3.21

# Set working directory
WORKDIR /app

# Copy only production node_modules from builder
COPY --from=builder /app/node_modules ./node_modules

# Copy application source code and database directory
COPY server/src/ ./src/
COPY server/database/ ./database/

# Create non-root user for security
RUN addgroup -S appuser && adduser -S appuser -G appuser

# Switch to non-root user
USER appuser

# Expose application port
EXPOSE 5001

# Health check using the existing /api/health endpoint
HEALTHCHECK --interval=30s --timeout=5s --retries=3 CMD wget -qO- http://localhost:5001/api/health || exit 1

# Start the application
CMD ["node", "src/index.js"]